# プロジェクト軽量化: Cursorのインデックス対象から除外
# 除外してもコード内でパス参照は可能です（検索・インデックスのみ対象外）

# Git履歴（約52MB）
.git/

# 画像フォルダ（約54MB・プロジェクトの約半分）
img/

# バックアップ（不要なら削除可）
backups/

# 旧版・バックアップPHP（参照するまで不要なら削除可）
*-OLD.php
*-BACKUP.php

# 外部ライブラリCSS（インデックス不要）
css/swiper-bundle.css
css/aos.css

# 参照用URL一覧（約600KB、インデックス不要）
nubow-production-urls.txt
